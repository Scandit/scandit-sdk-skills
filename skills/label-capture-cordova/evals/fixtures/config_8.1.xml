<?xml version='1.0' encoding='utf-8'?>
<widget id="com.example.labelcapture" version="0.1.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
  <name>LabelCaptureApp</name>
  <description>Label Capture Cordova sample app.</description>
  <content src="index.html" />
  <plugin name="cordova-plugin-whitelist" spec="^1.3.0" />
  <plugin name="scandit-cordova-datacapture-core" spec="^8.1.0" />
  <plugin name="scandit-cordova-datacapture-barcode" spec="^8.1.0" />
  <plugin name="scandit-cordova-datacapture-label" spec="^8.1.0" />
  <platform name="ios">
    <preference name="deployment-target" value="14.0" />
  </platform>
  <platform name="android">
    <preference name="android-minSdkVersion" value="23" />
  </platform>
</widget>
